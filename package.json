{
  "name": "@manual.email",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@ai-sdk/google": "3.0.80",
      "@better-auth/infra": "0.2.11",
      "@biomejs/biome": "2.4.16",
      "@cloudflare/sandbox": "0.11.0",
      "@cloudflare/vite-plugin": "1.39.2",
      "@monaco-editor/react": "4.7.0",
      "@orpc/contract": "1.14.4",
      "@phosphor-icons/react": "2.1.10",
      "@tailwindcss/postcss": "4.3.0",
      "@types/node": "20.19.41",
      "@types/react": "19.2.16",
      "@types/react-dom": "19.2.3",
      "@vitejs/plugin-react": "6.0.2",
      "@vitejs/plugin-rsc": "0.5.27",
      "ai": "6.0.196",
      "better-auth": "1.6.14",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "drizzle-kit": "0.31.10",
      "drizzle-orm": "0.45.2",
      "knip": "6.15.0",
      "monaco-editor": "0.55.1",
      "next": "16.2.7",
      "postal-mime": "2.7.4",
      "pokayoke": "0.0.3",
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "react-server-dom-webpack": "19.2.7",
      "tailwindcss": "4.3.0",
      "typescript": "6.0.3",
      "vinext": "0.0.55",
      "vite": "8.0.16",
      "wrangler": "4.97.0",
      "zod": "4.4.3"
    }
  },
  "scripts": {
    "dev": "bun --filter '*' --elide-lines 0 dev",
    "dev:web": "bun --filter '@manual.email/web' dev",
    "dev:ingress": "bun --filter '@manual.email/ingress' dev",
    "dev:egress": "bun --filter '@manual.email/egress' dev",
    "dev:workers": "bun --filter '@manual.email/ingress' --filter '@manual.email/egress' --elide-lines 0 dev",
    "build": "bun --filter '*' build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "pokayoke": "pokayoke check",
    "pokayoke:fix": "pokayoke check --fix",
    "pokayoke:test": "bun test ./.pokayoke/rules/enforce-arrow-function.test.ts ./.pokayoke/rules/max-file-lines.test.ts ./.pokayoke/rules/one-ui-component-per-file.test.ts ./.pokayoke/rules/ui-source-buckets.test.ts",
    "check": "biome check . && bun run typecheck && knip && bun run pokayoke",
    "deploy": "bun run db:migrate:prod && bun --filter '*' deploy",
    "deploy:web": "bun run db:migrate:prod && bun --filter '@manual.email/web' deploy",
    "deploy:ingress": "bun run db:migrate:prod && bun --filter '@manual.email/ingress' deploy",
    "deploy:egress": "bun run db:migrate:prod && bun --filter '@manual.email/egress' deploy",
    "typecheck": "bun run cf-typegen && bun --filter '*' typecheck",
    "cf-typegen": "bun --filter '@manual.email/ingress' --filter '@manual.email/egress' --filter '@manual.email/web' cf-typegen",
    "db:generate": "bun --filter '@manual.email/db' db:generate",
    "db:migrate:local": "bun --filter '@manual.email/db' db:migrate:local",
    "db:seed:local": "bun --filter '@manual.email/db' db:seed:local",
    "db:splat:local": "bun --filter '@manual.email/db' db:splat:local",
    "db:migrate:prod": "bun --filter '@manual.email/db' db:migrate:prod"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "knip": "catalog:",
    "pokayoke": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "overrides": {
    "kysely": "0.28.17"
  }
}
