{
  "name": "@manual.email",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "appraise"
  ],
  "scripts": {
    "dev": "bun --filter '*' --elide-lines 0 dev",
    "dev:web": "bun --filter '@manual.email/web' dev",
    "dev:ingress": "bun --filter '@manual.email/ingress' dev",
    "dev:egress": "bun --filter '@manual.email/egress' dev",
    "dev:workers": "bun --filter '@manual.email/ingress' --filter '@manual.email/egress' --elide-lines 0 dev",
    "build": "bun --filter '*' build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "appraise": "bun run appraise/index.ts",
    "check": "biome check . && bun run typecheck && knip && bun run appraise",
    "deploy": "bun --filter '*' deploy",
    "deploy:web": "bun --filter '@manual.email/web' deploy",
    "deploy:ingress": "bun --filter '@manual.email/ingress' deploy",
    "deploy:egress": "bun --filter '@manual.email/egress' deploy",
    "typecheck": "bun run cf-typegen && bun --filter '*' typecheck",
    "cf-typegen": "bun --filter '@manual.email/ingress' --filter '@manual.email/egress' cf-typegen",
    "db:generate": "bun --filter '@manual.email/db' db:generate",
    "db:migrate:local": "bun --filter '@manual.email/ingress' db:migrate:local",
    "db:migrate": "bun --filter '@manual.email/ingress' db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "knip": "6.15.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
