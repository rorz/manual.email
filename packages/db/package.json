{
  "name": "@manual.email/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./address": "./src/address.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./keys": "./src/keys.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply manual-email --local --persist-to ../../.wrangler/state",
    "db:migrate:prod": "wrangler d1 migrations apply manual-email --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "wrangler": "catalog:"
  }
}
