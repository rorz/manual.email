{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "c07bb08e-b372-4a26-b887-35b5329885fb",
      "database_name": "manual-email",
      "migrations_dir": "./migrations"
    }
  ],
  // Not a deployed Worker. This config exists only so `wrangler d1 migrations
  // apply` has the D1 binding + migrations dir — packages/db owns the schema,
  // the generated migrations, and applying them (local + prod).
  "name": "manual-email-db"
}
